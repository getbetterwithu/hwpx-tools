      "2011": "http://www.hancom.co.kr/hwpml/2011/paragraph",
      "2024": "http://www.owpml.org/owpml/2024/paragraph"
    },
    "hp10": {
      "purpose": "paragraph 2016 확장 (alternate content용 신규 속성)",
      "2011": "http://www.hancom.co.kr/hwpml/2016/paragraph",
      "2024": "http://www.owpml.org/owpml/2024/paragraph10"
    },
    "hs": {
      "purpose": "section (Contents/sectionN.xml의 루트 hs:sec)",
      "2011": "http://www.hancom.co.kr/hwpml/2011/section",
      "2024": "http://www.owpml.org/owpml/2024/section"
    },
    "hh": {
      "purpose": "head (header.xml — fontfaces, borderFills, charPr, paraPr, styles 등)",
      "2011": "http://www.hancom.co.kr/hwpml/2011/head",
      "2024": "http://www.owpml.org/owpml/2024/head"
    },
    "hc": {
      "purpose": "core (color, fillBrush, points, matrix, margin 공통 타입)",
      "2011": "http://www.hancom.co.kr/hwpml/2011/core",
      "2024": "http://www.owpml.org/owpml/2024/core"
    },
    "hv": {
      "purpose": "version (version.xml)",
      "2011": "http://www.hancom.co.kr/hwpml/2011/version",
      "2024": "http://www.owpml.org/owpml/2024/version"
    },
    "ha": {
      "purpose": "app (settings.xml — application config)",
      "2011": "http://www.hancom.co.kr/hwpml/2011/app",
      "2024": "http://www.owpml.org/owpml/2024/app"
    },
    "hhs": {
      "purpose": "history (변경 이력)",
      "2011": "http://www.hancom.co.kr/hwpml/2011/history",
      "2024": "http://www.owpml.org/owpml/2024/history"
    },
    "hm": {
      "purpose": "master-page",
      "2011": "http://www.hancom.co.kr/hwpml/2011/master-page",
      "2024": "http://www.owpml.org/owpml/2024/master-page"
    },
    "hpf": {
      "purpose": "package file (content.hpf 매니페스트)",
      "2011": "http://www.hancom.co.kr/schema/2011/hpf",
      "2024": "http://www.owpml.org/owpml/2024/hpf"
    },
    "hwpunitchar": {
      "purpose": "HwpUnitChar (2016 확장 — 문자 단위 보강)",
      "2011": "http://www.hancom.co.kr/hwpml/2016/HwpUnitChar",
      "2024": "http://www.owpml.org/owpml/2024/hwpunitchar"
    },
    "ooxmlchart": {
      "purpose": "OOXML 차트 호환 (alternatecontent 안에서 사용)",
      "2011": "http://www.hancom.co.kr/hwpml/2016/ooxmlchart",
      "2024": "http://www.owpml.org/owpml/2024/ooxmlchart"
    },
    "dc": {
      "purpose": "Dublin Core (메타데이터)",
      "2011": "http://purl.org/dc/elements/1.1/",
      "2024": "http://purl.org/dc/elements/1.1/"
    },
    "opf": {
      "purpose": "EPUB OPF (content.hpf 안에서 패키지·매니페스트·스파인 표현)",
      "2011": "http://www.idpf.org/2007/opf/",
      "2024": "http://www.idpf.org/2007/opf/"
    },
    "ocf": {
      "purpose": "OCF container (META-INF/container.xml)",
      "2011": "urn:oasis:names:tc:opendocument:xmlns:container",
      "2024": "urn:oasis:names:tc:opendocument:xmlns:container"
    },
    "odf": {
      "purpose": "ODF manifest (META-INF/manifest.xml)",
      "2011": "urn:oasis:names:tc:opendocument:xmlns:manifest:1.0",
